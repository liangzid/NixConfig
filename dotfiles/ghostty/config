theme = Aura

term = xterm-256color
background-opacity = 0.8

font-family = FiraCode Nerd Font
font-size = 11

# ── Emacs-style (C-x prefix) ──
keybind = ctrl+x>2=new_split:down
keybind = ctrl+x>3=new_split:right
keybind = ctrl+x>1=toggle_split_zoom
keybind = ctrl+x>0=close_surface
keybind = ctrl+x>o=goto_split:next
keybind = ctrl+x>k=close_surface
keybind = ctrl+x>b=toggle_tab_overview

# ── Tab switching (Alt+number) ──
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=goto_tab:9

# ── Frequent shortcuts ──
keybind = ctrl+shift+t=new_tab
keybind = ctrl+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+enter=new_split:auto
