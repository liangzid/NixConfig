// Zellij — Emacs-style keybindings
// Prefix: C-x (like Emacs C-x prefix map)

keybinds {
    normal {
        bind "Ctrl x" { SwitchToMode "Locked"; }

        // Alt+number → switch tab
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
    }

    locked {
        // C-x 2 → split horizontal (new pane below)
        bind "2" { NewPane "Down"; SwitchToMode "Normal"; }
        // C-x 3 → split vertical (new pane right)
        bind "3" { NewPane "Right"; SwitchToMode "Normal"; }
        // C-x 1 → maximize (delete-other-windows)
        bind "1" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        // C-x 0 → close pane (delete-window)
        bind "0" { CloseFocus; SwitchToMode "Normal"; }
        // C-x o → next pane  (other-window)
        bind "o" { MoveFocus "Down"; SwitchToMode "Normal"; }
    }
}

theme "default"

pane_frames false
default_shell "fish"
